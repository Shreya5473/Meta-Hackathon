# Application
APP_ENV=development
APP_VERSION=0.2.0
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-32-byte-random-string

# Database
POSTGRES_USER=geotrade
POSTGRES_PASSWORD=geotrade_secret
POSTGRES_DB=geotrade
DATABASE_URL=postgresql+asyncpg://geotrade:geotrade_secret@localhost:5432/geotrade
DATABASE_SYNC_URL=postgresql+psycopg2://geotrade:geotrade_secret@localhost:5432/geotrade
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SIMULATION=10/minute

# Model paths
MODEL_ARTIFACTS_DIR=./model_artifacts

# NLP
NLP_MODEL_NAME=cross-encoder/nli-distilroberta-base
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# GTI
GTI_DECAY_LAMBDA=0.05
GTI_VERSION=1.0.0

# Pipeline
PIPELINE_VERSION=1.0.0

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=geopulse-trader
ENABLE_OTEL=false

# Alert webhooks (optional)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────────────────────
# External API keys (optional — system works without them)
# ──────────────────────────────────────────────────────────────────────────────
# Uncomment and set these if you want real market data instead of synthetic:
# ALPHA_VANTAGE_API_KEY=your_key_here
# POLYGON_API_KEY=your_key_here
# FINNHUB_API_KEY=your_key_here
